{
	"name": "sqllens-sql",
	"displayName": "sqllens SQL",
	"description": "Multi-dialect SQL language support powered by the sqllens analyzer: diagnostics, typed hover, go-to-definition, references, completion, semantic tokens. Fully self-contained — the language server is bundled.",
	"version": "0.3.0",
	"publisher": "niclasolofsson",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/NiclasOlofsson/sqllens-language-server.git",
		"directory": "vscode-extension"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"keywords": [
		"sql",
		"lsp",
		"sqllens",
		"databricks",
		"snowflake",
		"postgres",
		"tsql",
		"duckdb"
	],
	"main": "./dist/extension.js",
	"activationEvents": [
		"onLanguage:sql",
		"onLanguage:sql-databricks",
		"onLanguage:sql-tsql",
		"onLanguage:sql-snowflake",
		"onLanguage:sql-bigquery",
		"onLanguage:sql-redshift",
		"onLanguage:sql-postgres",
		"onLanguage:sql-duckdb",
		"onLanguage:sql-trino",
		"onLanguage:sql-sqlite",
		"onLanguage:sql-mysql"
	],
	"contributes": {
		"languages": [
			{
				"id": "sql",
				"extensions": [
					".sql"
				],
				"aliases": [
					"SQL",
					"sql"
				]
			},
			{
				"id": "sql-databricks",
				"aliases": [
					"SQL (Databricks)"
				]
			},
			{
				"id": "sql-tsql",
				"aliases": [
					"SQL (T-SQL)"
				]
			},
			{
				"id": "sql-snowflake",
				"aliases": [
					"SQL (Snowflake)"
				]
			},
			{
				"id": "sql-bigquery",
				"aliases": [
					"SQL (BigQuery)"
				]
			},
			{
				"id": "sql-redshift",
				"aliases": [
					"SQL (Redshift)"
				]
			},
			{
				"id": "sql-postgres",
				"aliases": [
					"SQL (PostgreSQL)"
				]
			},
			{
				"id": "sql-duckdb",
				"aliases": [
					"SQL (DuckDB)"
				]
			},
			{
				"id": "sql-trino",
				"aliases": [
					"SQL (Trino)"
				]
			},
			{
				"id": "sql-sqlite",
				"aliases": [
					"SQL (SQLite)"
				]
			},
			{
				"id": "sql-mysql",
				"aliases": [
					"SQL (MySQL)"
				]
			}
		],
		"grammars": [
			{
				"language": "sql-databricks",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-tsql",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-snowflake",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-bigquery",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-redshift",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-postgres",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-duckdb",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-trino",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-sqlite",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			},
			{
				"language": "sql-mysql",
				"scopeName": "source.sql",
				"path": "./syntaxes/sql.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"package": "npm run build && vsce package",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"sqllens-language-server": "^0.3.0",
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.6.2",
		"typescript": "^6.0.3"
	}
}
