{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run VS Code extension (test workspace)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
				"${workspaceFolder}/temp_auto/localtest"
			],
			"outFiles": ["${workspaceFolder}/vscode-extension/dist/**/*.js"],
			"preLaunchTask": "npm: build - vscode-extension"
		}
	]
}
